{
  "name": "rushi-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "build:ios-web": "vite build --config vite.ios.config.ts",
    "lint": "eslint .",
    "check": "npm run lint && npm run build",
    "prerender:seo": "tsx --tsconfig tsconfig.app.json scripts/prerender-seo.tsx",
    "preview": "vite preview",
    "ios:sync": "npm run build:ios-web && cap sync ios",
    "ios:open": "cap open ios",
    "ios:sim-server": "sh -c 'if [ -f .env.local ]; then node --env-file=.env.local scripts/studio-app-sim-server.mjs; elif [ -f .env ]; then node --env-file=.env scripts/studio-app-sim-server.mjs; elif [ -f .vercel/.env.production.local ]; then node --env-file=.vercel/.env.production.local scripts/studio-app-sim-server.mjs; elif [ -f .vercel/.env.preview.local ]; then node --env-file=.vercel/.env.preview.local scripts/studio-app-sim-server.mjs; else node scripts/studio-app-sim-server.mjs; fi'"
  },
  "dependencies": {
    "@capacitor/browser": "^8.0.3",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.3.0",
    "@capacitor/share": "^8.0.1",
    "@gsap/react": "^2.1.1",
    "@react-three/cannon": "^6.6.0",
    "@react-three/drei": "^9.120.4",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.3",
    "@react-three/rapier": "^1.5.0",
    "@supabase/supabase-js": "^2.101.1",
    "@types/three": "^0.168.0",
    "@vercel/analytics": "^1.4.1",
    "gsap": "^3.12.7",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-fast-marquee": "^1.6.5",
    "react-icons": "^5.3.0",
    "react-router-dom": "^7.13.2",
    "three": "^0.168.0",
    "three-stdlib": "^2.33.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@eslint/js": "^9.9.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "supabase": "^2.84.6",
    "tsx": "^4.20.6",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1"
  }
}
